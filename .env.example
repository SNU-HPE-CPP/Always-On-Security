# Always-On Security — Environment Variable Template
# Copy this file to .env and fill in the values before running docker-compose.
#
# IMPORTANT: The HMAC_SECRET is an Infrastructure_Zone credential.
# It is passed ONLY to: controller, host-observer, security-monitor.
# It is NEVER passed to tenant node containers (node1-node4).

# Shared HMAC-SHA256 secret for telemetry authentication between
# infrastructure components. Use a cryptographically random value.
# Generate with: openssl rand -hex 32
HMAC_SECRET=change_me_use_openssl_rand_hex_32
