# Always-On Security — Environment Variables
# Copy this file to .env and fill in the values before running docker-compose.
#
# IMPORTANT: Never commit .env to version control.
# For air-gapped deployments, distribute this file out-of-band.

# ─────────────────────────────────────────────────────────────────────────────
# HMAC_SECRET (REQUIRED)
# Shared secret used for HMAC-SHA256 message signing between nodes and the
# controller. Must be identical on ALL services (nodes + controller).
#
# Generate a secure random value with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
#
# CRITICAL: If this is missing or differs between services, all node messages
# will fail HMAC verification and be dropped by the controller.
# ─────────────────────────────────────────────────────────────────────────────
HMAC_SECRET=REPLACE_WITH_A_64_CHARACTER_HEX_SECRET_GENERATED_SECURELY
